# Copy this file to `.env` to override defaults locally.
# `.env` is gitignored; this `.env.example` is committed as documentation
# of the project's environment variable contract.

# Express API server port. Defaults to 3001 when unset.
# The Vite dev server (port 5173) proxies /api/* to this port.
PORT=3001

# SQL Lite DB
LEDGER_DB=